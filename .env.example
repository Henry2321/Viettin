## Backend API keys (do NOT commit your real .env)
OPENAI_API_KEY=your_openai_key_here
## Optional: point to OpenAI-compatible proxy if needed
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
GROQ_API_KEY=your_groq_key_here
HF_API_TOKEN=your_huggingface_token_here

## Groq vision model (the previous preview can be deprecated; override here)
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

## Virtual try-on HF Space (default may go down; override here)
## Recommended to try official IDM-VTON if nymbo space is in error:
## VTON_SPACE_URL=https://yisol-idm-vton.hf.space
VTON_SPACE_URL=https://nymbo-virtual-try-on.hf.space
## For yisol/IDM-VTON, api_name is `tryon`
VTON_API_NAME=tryon
VTON_AUTO_MASK=true
VTON_AUTO_CROP=false
VTON_DENOISE_STEPS=30
VTON_SEED=42

## Optional: preset prompt for AI Try-On
## - Use `{shirt_desc}` placeholder to inject Vision shirt description
## - You can write line breaks as \n
TRYON_PROMPT_EN_TEMPLATE=Use the provided person photo as the main subject. Replace the person's current clothing with this reference shirt: {shirt_desc}. Keep the person's face, hairstyle, body shape, and pose exactly the same. Apply precisely the patterns, colors, material texture and cut of the reference shirt. Ensure the shirt fits naturally with realistic fabric wrinkles and shadows. Natural lighting, ultra-high detail, photorealistic, 4K resolution.
TRYON_NEG_PROMPT=cartoon, anime, painting, drawing, 3d render, blurry, low quality, deformed face, changed face, different person, extra limbs, watermark, text
TRYON_PROMPT_VI=Sử dụng hình ảnh người tôi cung cấp làm chủ thể chính.\nThay áo hiện tại của người đó bằng chiếc áo trong hình áo mẫu tôi cung cấp.\nGiữ nguyên khuôn mặt, kiểu tóc, dáng người và tư thế của người.\nÁp chính xác họa tiết, màu sắc, chất liệu và form áo từ ảnh mẫu lên cơ thể người.\nĐảm bảo áo ôm tự nhiên theo cơ thể, có độ nhăn vải và đổ bóng chân thực.\nẢnh trông như chụp thật, ánh sáng tự nhiên, chi tiết cao, realistic, 4K.
